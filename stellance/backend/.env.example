DATABASE_URL="postgresql://postgres:password@localhost:5432/stella?schema=public"

# JWT signing secret (set a strong random value in production)
JWT_SECRET="change-me"

# Access token TTL (supported formats: 900s, 15m, 1h, 7d)
JWT_ACCESS_EXPIRES_IN="15m"

# Refresh token TTL in days
JWT_REFRESH_DAYS="30"

# Extra secret mixed into refresh-token hashing (keep private like JWT_SECRET)
REFRESH_TOKEN_PEPPER="change-me-too"

# CORS
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Stellar / Soroban ────────────────────────────────────────────────────────

# Network: "testnet" | "mainnet"
STELLAR_NETWORK="testnet"

# Horizon REST API (leave blank to use the default for STELLAR_NETWORK)
# STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"

# Soroban RPC endpoint (leave blank to use the default for STELLAR_NETWORK)
# STELLAR_RPC_URL="https://soroban-testnet.stellar.org"

# Network passphrase (leave blank to use the default for STELLAR_NETWORK)
# STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Deployed Soroban escrow contract address (set after: stellar contract deploy ...)
ESCROW_CONTRACT_ID=""

# Platform admin Stellar secret key — used to sign release/refund/dispute transactions.
# Generate with: stellar keys generate admin --network testnet
# NEVER commit a real secret key.
STELLAR_ADMIN_SECRET=""

# SEP-41 token contract address for payments.
# For XLM on testnet use the wrapped native asset contract:
#   stellar contract id asset --asset native --network testnet
# For USDC on testnet: GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
STELLAR_TOKEN_CONTRACT_ID=""
